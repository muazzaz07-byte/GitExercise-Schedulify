<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Schedulify - Create Account</title>
    <link rel="stylesheet" href="login.css">
</head>

<body>

    <!-- OVERLAY -->
    <div class="overlay"></div>

    <!-- HEADER -->
    <header class="header">
        <img src="logo.png" alt="Schedulify Logo" class="logo-besar">
    </header>

    <!-- MAIN -->
    <main class="container">
        <div class="card">
            <h2 class="card-title">Create Account</h2>
            
            <form class="form-group">
                <input type="email" placeholder="E-mail" class="input-field" required>
                <input type="password" placeholder="Password" class="input-field" required>
                
                <div class="button-container">
                    <button type="submit" class="btn">Sign Up</button>
                    <button type="button" class="btn">Sign In</button>
                </div>
            </form>
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <p>&copy; 2026 Schedulify Inc. All rights reserved</p>
    </footer>

</body>
</html>

--------------------------------------------CSS----------------------------------------------

/* RESET */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', sans-serif;
}

/* BODY (NO SCROLL) */
body {
    height: 100vh;
    overflow: hidden; /* 🔥 buang scroll */

    display: flex;
    flex-direction: column;

    background: url('background.png') no-repeat center center;
    background-size: cover;
    position: relative;
}

/* OVERLAY */
.overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    z-index: 1;
}

/* HEADER */
.header {
    flex: 0 0 auto;
    display: flex;
    justify-content: center;
    padding-top: 20px;
    z-index: 2;
}

/* LOGO BESAR */
.logo-besar {
    width: 300px;       /* 🔥 BESAR */
    max-width: 50vw;
    height: auto;
}

/* MAIN */
.container {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 2;
}

/* CARD LOGIN */
.card {
    width: 95%;
    max-width: 480px;      /* 🔥 BESAR */
    padding: 35px 35px;    /* 🔥 spacious */

    border-radius: 30px;
    text-align: center;

    background: linear-gradient(135deg, #a855f7, #22d3ee);
    box-shadow: 0 15px 30px rgba(0,0,0,0.3);
}

/* TITLE */
.card-title {
    font-size: 26px;
    color: white;
    margin-bottom: 25px;
    font-weight: bold;
}

/* FORM */
.form-group {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

/* INPUT */
.input-field {
    padding: 14px 22px;
    border-radius: 50px;
    border: none;
    font-size: 15px;
    outline: none;
}

/* BUTTON CONTAINER */
.button-container {
    display: flex;
    gap: 12px;
    margin-top: 10px;
}

/* BUTTON */
.btn {
    flex: 1;
    padding: 12px;
    border-radius: 50px;
    border: none;
    background: #f0fdfa;
    color: #0d9488;
    font-weight: bold;
    cursor: pointer;
    transition: 0.3s;
}

.btn:hover {
    transform: scale(1.05);
}

/* FOOTER */
.footer {
    flex: 0 0 auto;
    text-align: center;
    padding: 10px;
    z-index: 2;
}

.footer p {
    color: white;
    font-size: 12px;
}
